// Network builtins demo
println("net demo");
println(strlen(fetch("u")));
println(strlen(httpGet("u")));
println(strlen(httpPost("u", "x")));
println(strlen(httpPut("u", "x")));
println(strlen(httpDelete("u")));
println(download("u", "net_demo.bin"));
println(exists("net_demo.bin"));
println(strlen(upload("u", "net_demo.bin")));
println(websocketConnect("wss://example.com/ws"));
println(strlen(dnsLookup("localhost")) >= 7);
println(ping("localhost"));
println(removeFile("net_demo.bin"));
println("net done");
