// Array builtins demo
println("array demo");
let arr = push(0, 10);
push(arr, 20);
push(arr, 30);
println(arrlen(arr));
println(first(arr));
println(last(arr));
println(get(arr, 1));
set(arr, 1, 99);
println(get(arr, 1));
println(pop(arr));
println(arrlen(arr));
reverse(arr);
println(get(arr, 0));
println(get(arr, 1));
println("array done");
